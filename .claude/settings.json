{
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Read(./.dev.vars)",
      "Read(.dev.vars.*)",
      "Edit(./.dev.vars)",
      "Edit(.dev.vars.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/docs-drift.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/feature-shots-drift.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/impeccable-slop.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/engram-recall.sh\""
          }
        ]
      }
    ]
  }
}
