# Config de pnpm (npm-compatible). Los settings de supply-chain viven en pnpm-workspace.yaml.

# Integridad del store de contenido (verifica hashes al materializar).
verify-store-integrity=true

# Peers: instalar peers automáticamente pero no romper el install por conflictos menores.
auto-install-peers=true
strict-peer-dependencies=false
dedupe-peer-dependents=true

# Preferir el lockfile si está actualizado (reproducibilidad).
prefer-frozen-lockfile=true

# No permitir que un paquete raro fuerce una versión de Node distinta silenciosamente.
engine-strict=true
