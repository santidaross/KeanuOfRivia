{
  "name": "keanuofrivia-website",
  "version": "1.0.0",
  "description": "Sitio web personal de Keanu Of Rivia sobre Cloudflare Workers",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "dev:staging": "wrangler dev --env staging",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "tail": "wrangler tail",
    "tail:staging": "wrangler tail --env staging",
    "tail:production": "wrangler tail --env production",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "admin:get": "node admin-config.js get",
    "admin:update": "node admin-config.js update",
    "admin:delete": "node admin-config.js delete",
    "prepare": "lefthook install"
  },
  "keywords": ["cloudflare-workers", "personal-website", "minecraft", "serverless", "edge-computing"],
  "author": "Keanu Of Rivia",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "lefthook": "^1.7.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.27.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
